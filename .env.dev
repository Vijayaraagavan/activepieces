AP_API_KEY="api-key"
AP_CACHE_PATH="./dev/cache"
AP_CONFIG_PATH="./dev/config"

# --- Database Configuration ---
AP_DB_TYPE=POSTGRES
# Update these credentials to match your local Postgres setup
AP_POSTGRES_DATABASE="activepieces"
AP_POSTGRES_HOST="localhost"
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME="postgres"
AP_POSTGRES_PASSWORD="postgres"

# --- Development Pieces ---
# Added http, schedule, webhook, smtp, slack, and notion for robust local testing
AP_DEV_PIECES="google-sheets,store,http,schedule,webhook,smtp,slack,notion"

AP_ENVIRONMENT="dev"
AP_FRONTEND_URL="https://deedee-nonpredicative-ester.ngrok-free.dev"
AP_LOG_LEVEL=debug
AP_LOG_PRETTY=true
AP_QUEUE_MODE=MEMORY
AP_TELEMETRY_ENABLED=false
AP_TRIGGER_DEFAULT_POLL_INTERVAL=1
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_PIECES_SYNC_MODE=NONE
# vite proxies from frontend to this backend api
AP_WEBHOOK_URL="http://localhost:3000"
AP_LOAD_TRANSLATIONS_FOR_DEV_PIECES=false
AP_JWT_SECRET=dev-secret-please-change-in-production

AP_QUEUE_UI_ENABLED=true
AP_QUEUE_UI_USERNAME=admin
AP_QUEUE_UI_PASSWORD=admin

